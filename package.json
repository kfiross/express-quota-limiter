{
  "name": "express-quota-limiter",
  "version": "1.0.1",
  "description": "A flexible, driver-based quota limiter middleware for Express.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test",
    "release": "npm run build && changeset publish",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "express",
    "middleware",
    "quota",
    "rate-limit",
    "redis",
    "sql",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kfiross/express-quota-limiter.git"
  },
  "bugs": {
    "url": "https://github.com/kfiross/express-quota-limiter/issues"
  },
  "homepage": "https://github.com/kfiross/express-quota-limiter#readme",
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
